# ─── Frontend (Vite) ──────────────────────────────────────────────────────────
# These are bundled into the client — never put secrets here.
VITE_SUPABASE_PROJECT_ID="your_supabase_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_anon_key"
VITE_SUPABASE_URL="https://your_project_id.supabase.co"

# PostHog analytics (optional — analytics won't fire without this)
VITE_POSTHOG_KEY="phc_your_posthog_key"
VITE_POSTHOG_HOST="https://us.i.posthog.com"

# ─── Supabase Edge Function Secrets ──────────────────────────────────────────
# Set via: supabase secrets set KEY=value
# These are auto-provided by Supabase runtime:
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY

# AI / LLM providers
OPENROUTER_API_KEY="sk-or-..."
GEMINI_API_KEY="your_gemini_api_key"
LOVABLE_API_KEY="your_lovable_api_key"

# Speech & Audio
AZURE_SPEECH_KEY="your_azure_speech_key"
AZURE_SPEECH_REGION="eastus"
AZURE_SPEECH_ENDPOINT="https://eastus.api.cognitive.microsoft.com"
ELEVENLABS_API_KEY="your_elevenlabs_api_key"
DEEPGRAM_API_KEY="your_deepgram_api_key"
SONIOX_API_KEY="your_soniox_api_key"
MUNSIT_API_KEY="your_munsit_api_key"
MUNSIT_TTS_MODEL_ID="your_munsit_tts_model_id"
MUNSIT_GULF_VOICE_ID="your_munsit_gulf_voice_id"

# NLP / Translation
FANAR_API_KEY="your_fanar_api_key"
FARASA_API_KEY="your_farasa_api_key"
HUGGINGFACE_API_KEY="hf_..."
JINA_API_KEY="jina_..."

# Media & Content
RAPIDAPI_KEY="your_rapidapi_key"
YOUTUBE_API_KEY="your_youtube_api_key"
COBALT_API_KEY="your_cobalt_api_key"
FIRECRAWL_API_KEY="your_firecrawl_api_key"

# RunPod (GPU inference)
RUNPOD_API_KEY="your_runpod_api_key"
RUNPOD_ENDPOINT_URL="https://api.runpod.ai/v2/your_endpoint_id"
RUNPOD_CALLBACK_SECRET="your_runpod_callback_secret"

# Payments
STRIPE_SECRET_KEY="sk_live_or_test_..."

# Security
ALLOWED_ORIGINS="https://your-domain.com,http://localhost:5173"
